#!/bin/sh

launchctl setenv XSH_CONFIG_DIR "$HOME/.config/shell"
launchctl setenv GNUPGHOME "$HOME/.config/gnupg"

# gpgconf is in Homebrew which is not on launchd's default PATH
GPGCONF="/opt/homebrew/bin/gpgconf"
if [ -x "$GPGCONF" ]; then
  SSH_SOCK=$("$GPGCONF" --list-dirs agent-ssh-socket 2>/dev/null)
  [ -n "$SSH_SOCK" ] && launchctl setenv SSH_AUTH_SOCK "$SSH_SOCK"
fi
