ControlMaster auto
ControlPersist 60m
IgnoreUnknown UseKeychain

{% if yadm.hostname == "mw-mendres-JYJJ" %}
Match host ssh.runpod.io exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-runpod.pub

Host *.macfarm.va4
  User jenkins_agent
  Port 22

Host *.wooga-preprod.va4
  ProxyCommand boundary-ssh-proxy %h
  User atlas

Host boundary-agent
  ProxyCommand boundary-ssh-proxy
  User jenkins_agent

Host boundary-agent *.va4
  Port 22
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  SendEnv AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_REGION AWS_DEFAULT_REGION
  SendEnv ATLAS_READ_USR ATLAS_READ_PSW
  SetEnv CLICOLOR=1
  ControlMaster no
  ControlPath none

Match host boundary-agent,*.wooga-preprod.va4,*.macfarm.va4 exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-ed25519.pub

Host github-wooga
  HostName github.com
  User git

Host github-playtika
  HostName github.com
  User git

Match originalhost github-wooga exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/github-ed25519.pub

Match originalhost github-playtika exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-github-ed25519.pub
{% endif %}

# Parallels VM #
Host 10.211.55.*
  Port 22
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

Match host 10.211.55.* exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/parallels-vm-key.pub

# Local Network #

Match host minim4pro !localnetwork 192.168.188.0/24
  HostName larussominim4pro

Match host minim4pro localnetwork 192.168.188.0/24
  HostName larussominim4pro.fritz.box

Match host truenas localnetwork 192.168.188.0/24
  HostName truenas.fritz.box

Match originalhost truenas exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/truenas-ed25519.pub

Match host larusso* localnetwork 192.168.188.0/24
  User larusso
  Port 22
  HostName %h.fritz.box

Match host *.fritz.box exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/mac_mini_pro.pub

Match host github.com exec "test -z $SSH_TTY"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/github-ed25519.pub

Host 192.168.8.1 192.168.10.1
  StrictHostKeyChecking no

{% if yadm.hostname == "arch-ripper" %}
Host gitlab.com
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
Host aur.archlinux.org
  IdentityFile ~/.ssh/id_aur
  IdentitiesOnly yes
  User aur
{% endif %}

Host *
  ForwardAgent no
  Compression no
  ServerAliveInterval 0
  ServerAliveCountMax 3
  HashKnownHosts no
  ControlPath /tmp/ssh_mux_%n_%h_%p_%r
  ControlPersist no
  AddKeysToAgent yes
  UseKeychain yes

Match host * exec "test -z $SSH_TTY"
{% if yadm.os == "Darwin" %}
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{% endif %}
{% if yadm.os == "Linux" %}
  IdentityAgent "~/.1password/agent.sock"
{% endif %}
