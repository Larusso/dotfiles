ControlMaster auto
ControlPersist 60m
IgnoreUnknown UseKeychain


{% if yadm.hostname == "mw-mendres-JYJJ" %}
Host ssh.runpod.io
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-runpod.pub

Host *.macfarm.va4
  User jenkins_agent
  Port 22
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-ed25519.pub
  SendEnv AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_REGION AWS_DEFAULT_REGION
  SendEnv ATLAS_READ_USR ATLAS_READ_PSW

Host *.wooga-preprod.va4
  ProxyCommand boundary-ssh-proxy %h
  User atlas
  Port 22
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-ed25519.pub
  # Forward env to remote (server must AcceptEnv these)
  SendEnv AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_REGION AWS_DEFAULT_REGION
  SendEnv ATLAS_READ_USR ATLAS_READ_PSW
  ControlMaster no
  ControlPath none

Host boundary-agent
  ProxyCommand boundary-ssh-proxy
  User jenkins_agent
  Port 22
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  IdentitiesOnly yes
  IdentityFile ~/.ssh/keys/work-ed25519.pub
  SendEnv AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN AWS_REGION AWS_DEFAULT_REGION
  SendEnv ATLAS_READ_USR ATLAS_READ_PSW
  ControlMaster no
  ControlPath none
{% endif %}

