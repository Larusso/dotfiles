#!/usr/bin/env bash
#
# Bootstrap program for the system.
# Machine class is set interactively during bootstrap.
#
# Usage:
#   bash <(curl -fsSL https://raw.githubusercontent.com/Larusso/dotfiles/master/setup)
#
set -euo pipefail

os="$(uname)"
distro="unknown"
brew_home="/usr/local/bin"

green='\033[0;32m'
blue='\033[0;34m'
clear='\033[0m'

case $os in
  'Linux')
    os='Linux'
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        distro=$ID
    fi
    ;;
  'WindowsNT')
    os='Windows'
    ;;
  'Darwin')
    os='macOS'
    if [ "$(uname -m)" == "arm64" ]; then
        brew_home="/opt/homebrew/bin"
    fi
    ;;
  *) ;;
esac
echo -e "${green}::${clear} OS: ${os} / distro: ${distro}"

function install_paru {
  if ! command -v paru >/dev/null 2>&1; then
    echo -e "${blue}::${clear} installing paru..."
    sudo pacman -S --needed git base-devel --noconfirm
    git clone https://aur.archlinux.org/paru.git
    cd paru && makepkg -si --noconfirm && cd -
  else
    echo -e "${green}::${clear} paru already installed"
  fi
}

function init_homebrew {
  echo -e "${blue}::${clear} init homebrew..."
  if ! command -v brew >/dev/null 2>&1; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
  else
    echo -e "${green}::${clear} homebrew already installed"
  fi
}

function init_yadm {
  echo -e "${blue}::${clear} init yadm..."

  if ! command -v yadm >/dev/null 2>&1; then
    echo -e "${blue}::${clear} installing yadm..."
    if [[ "$os" == "macOS" ]]; then
      "${brew_home}/brew" install yadm
      yadm_bin="${brew_home}/yadm"
    elif [[ "$os" == "Linux" && "$distro" == "arch" ]]; then
      paru -S lsb-release yadm --noconfirm
      yadm_bin="yadm"
    fi
  else
    echo -e "${green}::${clear} yadm already installed"
    yadm_bin="yadm"
  fi

  if [[ -d "$HOME/.local/share/yadm/repo.git" ]]; then
    echo -e "${green}::${clear} yadm repo already present, pulling and re-running bootstrap..."
    "$yadm_bin" pull
    "$yadm_bin" bootstrap
  else
    "$yadm_bin" init -f
    "$yadm_bin" remote add origin https://github.com/Larusso/dotfiles.git
    "$yadm_bin" pull origin master --set-upstream
    "$yadm_bin" alt
    "$yadm_bin" bootstrap
  fi
}

if [[ "$os" == "macOS" ]]; then
  init_homebrew
elif [[ "$os" == "Linux" && "$distro" == "arch" ]]; then
  install_paru
fi

init_yadm
