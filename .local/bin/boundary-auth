#!/usr/bin/env bash

# Boundary authentication wrapper with caching
# Usage: boundary-auth [options]
#   --force    : Force re-authentication even if cached credentials are valid
#   --token    : Output only the authentication token
#   --env      : Output export statement for eval (e.g., eval $(boundary-auth --env))
#   -v         : Verbose output (debug logging)
#
# Caches authentication in ~/.cache/boundary/auth.json

set -euo pipefail

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/boundary"
cache_file="$cache_dir/auth.json"
keychain_service="boundary-auth"
keychain_account="$USER"
use_keychain=0

# Check if we're on macOS
if [[ "$(uname -s)" == "Darwin" ]] && command -v security >/dev/null 2>&1; then
  use_keychain=1
fi

force_auth=0
output_token=0
output_env=0
verbose=0

# Verbose logging function
log_verbose() {
  if [[ $verbose -eq 1 ]]; then
    echo "🔍 [VERBOSE] $*" >&2
  fi
}

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      force_auth=1
      shift
      ;;
    --token)
      output_token=1
      shift
      ;;
    --env)
      output_env=1
      shift
      ;;
    -v)
      verbose=1
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

log_verbose "Starting boundary-auth"
log_verbose "Using keychain: $use_keychain"
log_verbose "Force auth: $force_auth"
log_verbose "Output mode: token=$output_token, env=$output_env"

# Function to store credentials in keychain
store_in_keychain() {
  local auth_data="$1"
  
  log_verbose "Storing credentials in keychain (service=$keychain_service, account=$keychain_account)"
  
  # Delete existing entry if present
  security delete-generic-password -s "$keychain_service" -a "$keychain_account" 2>/dev/null || true
  
  # Store new credentials
  security add-generic-password -s "$keychain_service" -a "$keychain_account" -w "$auth_data" -U
  
  log_verbose "Credentials stored successfully in keychain"
}

# Function to retrieve credentials from keychain
get_from_keychain() {
  log_verbose "Retrieving credentials from keychain"
  local result
  result=$(security find-generic-password -s "$keychain_service" -a "$keychain_account" -w 2>/dev/null)
  if [[ -n "$result" ]]; then
    log_verbose "Credentials retrieved from keychain (length: ${#result} bytes)"
  else
    log_verbose "No credentials found in keychain"
  fi
  echo "$result"
}

# Function to check if cached credentials are valid
is_cache_valid() {
  log_verbose "Checking if cached credentials are valid"
  local auth_data
  
  if [[ $use_keychain -eq 1 ]]; then
    log_verbose "Using keychain for credential retrieval"
    # Get from keychain
    auth_data=$(get_from_keychain) || {
      log_verbose "Failed to retrieve from keychain"
      return 1
    }
  else
    log_verbose "Using file for credential retrieval: $cache_file"
    # Get from file
    if [[ ! -f "$cache_file" ]]; then
      log_verbose "Cache file does not exist"
      return 1
    fi
    auth_data=$(cat "$cache_file") || {
      log_verbose "Failed to read cache file"
      return 1
    }
  fi
  
  if [[ -z "$auth_data" ]]; then
    log_verbose "Auth data is empty"
    return 1
  fi
  
  log_verbose "Auth data retrieved successfully"
  
  # Extract expiration time from cache
  local expiration
  expiration=$(echo "$auth_data" | jq -r '.item.attributes.expiration_time' 2>/dev/null)
  
  if [[ $? -ne 0 ]]; then
    log_verbose "Failed to parse JSON with jq"
    return 1
  fi
  
  log_verbose "Expiration time from cache: $expiration"
  
  if [[ -z "$expiration" || "$expiration" == "null" ]]; then
    log_verbose "Expiration time is empty or null"
    return 1
  fi
  
  # Convert expiration time to epoch seconds
  log_verbose "Converting expiration time to epoch"
  local expire_epoch
  if date --version >/dev/null 2>&1; then
    log_verbose "Using GNU date"
    # GNU date
    expire_epoch=$(date -d "$expiration" +%s 2>/dev/null)
    log_verbose "GNU date result: $expire_epoch"
  else
    log_verbose "Using BSD date (macOS)"
    # BSD date (macOS) - try different formats
    # Try ISO 8601 with Z
    log_verbose "Trying format: %Y-%m-%dT%H:%M:%SZ"
    expire_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$expiration" +%s 2>/dev/null)
    if [[ -z "$expire_epoch" ]]; then
      log_verbose "First format failed, trying: %Y-%m-%dT%H:%M:%S%z"
      # Try ISO 8601 with timezone offset
      expire_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$expiration" +%s 2>/dev/null)
    fi
    if [[ -z "$expire_epoch" ]]; then
      log_verbose "Second format failed, trying: %Y-%m-%dT%H:%M:%S without Z"
      # Try with just parsing what we can
      expire_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${expiration%Z}" +%s 2>/dev/null)
    fi
    log_verbose "BSD date result: $expire_epoch"
  fi
  
  # If date parsing failed, consider cache invalid
  if [[ -z "$expire_epoch" || "$expire_epoch" == "0" ]]; then
    log_verbose "Date parsing failed completely"
    echo "⚠️  Could not parse expiration time: $expiration" >&2
    return 1
  fi
  
  local current_epoch
  current_epoch=$(date +%s)
  
  log_verbose "Expire epoch: $expire_epoch"
  log_verbose "Current epoch: $current_epoch"
  log_verbose "Difference: $((expire_epoch - current_epoch)) seconds"
  log_verbose "Required buffer: 300 seconds (5 minutes)"
  
  # Valid if expiration is in the future (with 5 minute buffer)
  if [[ $expire_epoch -gt $((current_epoch + 300)) ]]; then
    log_verbose "Expiration check passed (expires in $((expire_epoch - current_epoch)) seconds)"
    
    # Additional validation: check if token actually works with boundary
    log_verbose "Validating token with boundary server"
    local token
    token=$(echo "$auth_data" | jq -r '.item.attributes.token')
    
    if BOUNDARY_TOKEN="$token" boundary auth-methods list -format json >/dev/null 2>&1; then
      log_verbose "Token validation SUCCESSFUL - token is valid on server"
      return 0
    else
      log_verbose "Token validation FAILED - token rejected by server (possibly revoked)"
      echo "⚠️  Cached token is no longer valid (possibly revoked)" >&2
      return 1
    fi
  else
    log_verbose "Cache is INVALID (expired or expires within 5 minutes)"
    echo "⚠️  Cached credentials expired" >&2
    return 1
  fi
}

# Function to authenticate and cache
authenticate() {
  echo "🔐 Authenticating with Boundary..." >&2
  log_verbose "Running: boundary authenticate oidc -format json"
  
  # Run boundary authenticate and save to cache
  local auth_output
  auth_output=$(boundary authenticate oidc -format json)
  
  log_verbose "Authentication command completed"
  log_verbose "Response length: ${#auth_output} bytes"
  
  # Validate the output
  if ! echo "$auth_output" | jq -e '.item.attributes.token' >/dev/null 2>&1; then
    log_verbose "Failed to parse token from response"
    echo "❌ Authentication failed or invalid response" >&2
    exit 1
  fi
  
  log_verbose "Authentication response validated"
  
  # Save to cache
  if [[ $use_keychain -eq 1 ]]; then
    log_verbose "Storing in keychain"
    # Store in keychain
    store_in_keychain "$auth_output"
  else
    log_verbose "Storing in file: $cache_file"
    # Store in file
    mkdir -p "$cache_dir"
    echo "$auth_output" > "$cache_file"
    chmod 600 "$cache_file"
    log_verbose "File stored with permissions 600"
  fi
  
  echo "$auth_output"
}

# Main logic
log_verbose "Starting main authentication flow"
auth_response=""

if [[ $force_auth -eq 1 ]]; then
  log_verbose "Force authentication requested"
  # Force re-authentication
  auth_response=$(authenticate)
elif is_cache_valid; then
  log_verbose "Cache is valid, using cached credentials"
  # Use cached credentials
  echo "✓ Using cached credentials" >&2
  if [[ $use_keychain -eq 1 ]]; then
    log_verbose "Retrieving from keychain"
    auth_response=$(get_from_keychain)
  else
    log_verbose "Reading from file"
    auth_response=$(cat "$cache_file")
  fi
  log_verbose "Cached credentials retrieved"
else
  log_verbose "Cache is invalid or doesn't exist, authenticating"
  # Cache invalid or doesn't exist, authenticate
  auth_response=$(authenticate)
fi

log_verbose "Auth response length: ${#auth_response} bytes"

# Determine output mode
if [[ $output_token -eq 1 ]]; then
  log_verbose "Output mode: token only"
  # Just output the token
  token=$(echo "$auth_response" | jq -r '.item.attributes.token')
  log_verbose "Token length: ${#token} characters"
  echo "$token"
elif [[ $output_env -eq 1 ]]; then
  log_verbose "Output mode: environment export"
  # Output export statement for eval
  token=$(echo "$auth_response" | jq -r '.item.attributes.token')
  log_verbose "Token length: ${#token} characters"
  echo "export BOUNDARY_AUTH_TOKEN='$token'"
else
  log_verbose "Output mode: none (status only)"
fi
log_verbose "boundary-auth completed successfully"
# Otherwise (default), no output - just status messages to stderr
