#!/usr/bin/env bash

# Remote shell script with AWS credentials forwarding
# Usage: remote-shell [-p PORT] [-w|-a] CONNECTION
#   -p PORT    : Specify SSH port (default: 22)
#   -w         : Target is a Windows host (uses PowerShell)
#   -a         : Auto-detect OS using uname (default)
#   CONNECTION : SSH connection string (user@host)

port=""
windows=0
autodetect=1
OPTIND=1

# Parse options
while getopts "p:wa" opt; do
  case "$opt" in
    p) port="$OPTARG" ;;
    w) 
      windows=1
      autodetect=0
      ;;
    a) 
      autodetect=1
      windows=0
      ;;
    *) 
      echo "Usage: remote-shell [-p PORT] [-w|-a] CONNECTION" >&2
      exit 1 
      ;;
  esac
done
shift $((OPTIND - 1))

conn="$1"
shift

if [[ -z "$conn" ]]; then
  echo "❌ Connection string required" >&2
  echo "Usage: remote-shell [-p PORT] [-w] CONNECTION" >&2
  exit 1
fi

profile="${AWS_PROFILE:-atlas}"
saml_cred_file="$HOME/.cache/saml2aws/credentials"

# Use SAML credentials file if it exists
if [[ -f "$saml_cred_file" ]]; then
  credfile="$saml_cred_file"
else
  credfile="$HOME/.aws/credentials"
fi

# Helper to read from chosen credentials file
get_aws_cred() {
  AWS_SHARED_CREDENTIALS_FILE="$credfile" aws configure get "$1" --profile "$profile"
}

access_key="${AWS_ACCESS_KEY_ID:-$(get_aws_cred aws_access_key_id)}"
secret_key="${AWS_SECRET_ACCESS_KEY:-$(get_aws_cred aws_secret_access_key)}"
session_token="${AWS_SESSION_TOKEN:-$(get_aws_cred aws_session_token)}"
region="${AWS_REGION:-$(get_aws_cred region)}"

if [[ -z "$access_key" || -z "$secret_key" ]]; then
  echo "❌ AWS credentials not found for profile '$profile'" >&2
  exit 1
fi

# Build ssh command with optional port
ssh_cmd="ssh -t"
if [[ -n "$port" ]]; then
  ssh_cmd="$ssh_cmd -p $port"
fi

# Auto-detect OS if needed
if [[ $autodetect -eq 1 ]]; then
  # Probe the remote system to detect OS
  uname_output=$(ssh -o ConnectTimeout=5 -o BatchMode=yes ${port:+-p $port} "$conn" "uname -a" 2>/dev/null)
  
  if echo "$uname_output" | grep -qiE 'mingw|msys|cygwin|windows'; then
    # Windows environment detected
    windows=1
  elif [[ -z "$uname_output" ]]; then
    # uname failed, might be Windows - try a Windows-specific check
    if ssh -o ConnectTimeout=5 -o BatchMode=yes ${port:+-p $port} "$conn" "echo %OS%" 2>/dev/null | grep -qi "windows"; then
      windows=1
    fi
  fi
  # Otherwise windows stays 0 (Unix/Linux)
fi

if [[ $windows -eq 1 ]]; then
  # Windows PowerShell syntax - use -NoExit to keep shell open
  $ssh_cmd "$conn" powershell -NoLogo -NoExit -Command "\$env:ATLAS_READ_USR='$ATLAS_READ_USR'; \$env:ATLAS_READ_PSW='$ATLAS_READ_PSW'; \$env:AWS_ACCESS_KEY_ID='$access_key'; \$env:AWS_SECRET_ACCESS_KEY='$secret_key'; \$env:AWS_SESSION_TOKEN='$session_token'; \$env:AWS_REGION='$region'; \$env:AWS_DEFAULT_REGION='$region'"
else
  # Unix/Linux shell syntax
  $ssh_cmd "$conn" \
    "ATLAS_READ_USR='$ATLAS_READ_USR' \
     ATLAS_READ_PSW='$ATLAS_READ_PSW' \
     AWS_ACCESS_KEY_ID='$access_key' \
     AWS_SECRET_ACCESS_KEY='$secret_key' \
     AWS_SESSION_TOKEN='$session_token' \
     AWS_REGION='$region' \
     AWS_DEFAULT_REGION='$region' \
     exec \$SHELL -l"
fi
